#include <behaviors/rgbled_widget.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

// OS設定を日本語キーボードのまま使用するための変換定義

#define JP_DOUBLE_QUOTES       AT                // "
#define JP_AMPERSAND    CARET             // &
#define JP_QUOTE        AMPERSAND         // '
#define JP_EQUAL        UNDER             // =
#define JP_CARET        EQUAL             // ^
#define JP_YEN          0x89              // ¥
#define JP_PLUS         COLON             // +
#define JP_TILDE        PLUS              // ~
#define JP_PIPE         LS(0x89)          // |
#define JP_AT           LEFT_BRACKET      // @
#define JP_COLON        SINGLE_QUOTE      // :
#define JP_ASTERISK     DOUBLE_QUOTES     // *
#define JP_BACKQUOTE    LEFT_BRACE        // `
#define JP_UNDERSCORE   LS(0x87)          // _
#define JP_LEFT_BRACKET     RIGHT_BRACKET     // [
#define JP_RIGHT_BRACKET     BACKSLASH         // ]
#define JP_LEFT_PARENTHESIS       ASTERISK          // (
#define JP_RIGHT_PARENTHESIS       LEFT_PARENTHESIS  // )
#define JP_LEFT_BRACE       RIGHT_BRACE       // {
#define JP_RIGHT_BRACE       PIPE              // }
#define JP_KANA         LANGUAGE_1        // かな
#define JP_EISU         LANGUAGE_2        // 英数
#define JP_HANZEN       GRAVE             // 半角/全角

&mt {
    quick-tap-ms = <175>;
    flavor = "tap-preferred";
};

/ {
    combos {
        compatible = "zmk,combos";

        IME_ON {
            bindings = <&imeonoff LA(GRAVE) LANGUAGE_1>;
            key-positions = <19 20>;
            layers = <0 1>;
        };

        win_mv_right {
            bindings = <&winmvright>;
            key-positions = <20 21>;
            slow-release;
            layers = <0 1>;
        };

        win_mv_left {
            bindings = <&winmvleft>;
            key-positions = <10 11>;
            slow-release;
            layers = <0 1>;
        };

        brackets {
            bindings = <&brack 0 0>;
            key-positions = <22 33>;
            layers = <0 1>;
        };

        parenthesis {
            bindings = <&paren 0 0>;
            key-positions = <10 21>;
            layers = <0 1>;
        };

        find_replace {
            bindings = <&holdtap LC(H) LC(F)>;
            key-positions = <22 23>;
            layers = <0 1>;
        };

        paste {
            bindings = <&holdtap LG(V) LC(V)>;
            key-positions = <18 19>;
            layers = <0 1>;
        };

        dblsft {
            bindings = <&DBLSFT>;
            key-positions = <12 13>;
            layers = <0 1>;
        };

        IME_OFF {
            bindings = <&kp LANGUAGE_2>;
            key-positions = <11 12>;
            layers = <0 1>;
        };

        braces {
            bindings = <&brace 0 0>;
            key-positions = <0 9>;
            layers = <0 1>;
        };

        undo {
            bindings = <&kp LC(Z)>;
            key-positions = <23 24>;
            layers = <0 1>;
        };

        redo {
            bindings = <&kp LC(Y)>;
            key-positions = <31 32>;
            layers = <0 1>;
        };

        taskview {
            bindings = <&kp LG(TAB)>;
            key-positions = <18 19>;
            layers = <4>;
        };

        close {
            bindings = <&holdtap LA(F4) LC(W)>;
            key-positions = <8 9>;
            layers = <0 1>;
        };

        maximize {
            bindings = <&kp LG(UP_ARROW)>;
            key-positions = <7 8>;
            layers = <0 1>;
        };

        minimize {
            bindings = <&kp LG(DOWN)>;
            key-positions = <6 7>;
            layers = <0 1>;
            timeout-ms = <50>;
            require-prior-idle-ms = <500>;
        };

        browse_back {
            bindings = <&kp LA(LEFT)>;
            key-positions = <0 1>;
            slow-release;
            layers = <0 1>;
        };

        browse_forward {
            bindings = <&kp LA(RIGHT)>;
            key-positions = <1 2>;
            slow-release;
            layers = <0 1>;
        };
    };

    macros {
        DBLSFT: DBLSFT {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_SHIFT &kp LEFT_SHIFT>;
        };

        DBLCTL: DBLCTL {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LCTRL &kp LCTRL>;
        };

        winmvright: winmvright {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_GUI &kp RIGHT>,
                <&macro_release>,
                <&kp RIGHT &kp LEFT_WIN>;
        };

        winmvleft: winmvleft {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_GUI &kp LEFT>,
                <&macro_release>,
                <&kp LEFT &kp LEFT_WIN>;
        };

        at: at {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp AT_SIGN>;
        };

        hash: hash {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp HASH>;
        };

        amp: amp {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp AMPERSAND>;
        };

        dollar: doller {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp DOLLAR>;
        };

        backquote: backquote {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp GRAVE>;
        };

        quote: quote {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp SINGLE_QUOTE>;
        };

        doublequote: doublequote {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp DOUBLE_QUOTES>;
        };

        caret: caret {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp CARET>;
        };

        pipe: pipe {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp PIPE>;
        };

        jp_at: jp_at {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp JP_AT>;
        };

        jp_amp: jp_amp {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp JP_AMPERSAND>;
        };

        jp_quote: jp_quote {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp JP_QUOTE>;
        };

        jp_doublequote: jp_doublequote {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp JP_DOUBLE_QUOTES>;
        };

        jp_caret: jp_caret {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp JP_CARET>;
        };

        jp_pipe: jp_pipe {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp JP_PIPE>;
        };

        parenthesis: parenthesis {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp LEFT_PARENTHESIS &kp RIGHT_PARENTHESIS &kp LEFT_ARROW>;
        };

        brackets: brackets {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp LEFT_BRACKET &kp RIGHT_BRACKET &kp LEFT>;
        };

        braces: braces {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp LEFT_BRACE &kp RIGHT_BRACE &kp LEFT>;
        };

        zen_parenthesis: zen_parenthesis {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_1 &kp LEFT_PARENTHESIS &kp RIGHT_PARENTHESIS &kp ENTER &kp LEFT_ARROW>;
        };

        zen_brackets: zen_brackets {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_1 &kp LEFT_BRACKET &kp RIGHT_BRACKET &kp ENTER &kp LEFT>;
        };

        zen_braces: zen_braces {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_1 &kp LEFT_BRACE &kp RIGHT_BRACE &kp ENTER &kp LEFT>;
        };

        jp_backquote: jp_backquote {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANGUAGE_2 &kp LEFT_BRACE>;
            label = "JP_BACKQUOTE";
        };
    };

    behaviors {
        BSDEL: BSDEL {
            compatible = "zmk,behavior-mod-morph";
            bindings = <&kp BSPC>, <&kp DELETE>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        lt_bsdel: lt_bsdel {
            compatible = "zmk,behavior-hold-tap";
            bindings = <&mo>, <&BSDEL>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <300>;
            flavor = "tap-preferred";
        };

        imeonoff: imeonoff {
            compatible = "zmk,behavior-hold-tap";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        holdtap: holdtap {
            compatible = "zmk,behavior-hold-tap";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <300>;
            flavor = "tap-preferred";
            quick-tap-ms = <250>;
            require-prior-idle-ms = <150>;
            hold-trigger-on-release;
        };

        paren: paren {
            compatible = "zmk,behavior-hold-tap";
            bindings = <&zen_parenthesis>, <&parenthesis>;

            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
        };

        brack: brack {
            compatible = "zmk,behavior-hold-tap";
            bindings = <&zen_brackets>, <&brackets>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        brace: brace {
            compatible = "zmk,behavior-hold-tap";
            bindings = <&zen_braces>, <&braces>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        mkp_layer: mkp_layer {
            compatible = "zmk,behavior-hold-tap";
            bindings = <&mo>, <&mkp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        slash: slash {
            compatible = "zmk,behavior-mod-morph";
            bindings = <&kp SLASH>, <&kp BACKSLASH>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        mt_slash: mt_slash {
            compatible = "zmk,behavior-hold-tap";
            bindings = <&kp>, <&slash>;

            #binding-cells = <2>;
            tapping-term-ms = <300>;
            quick-tap-ms = <250>;
            require-prior-idle-ms = <150>;
            flavor = "tap-preferred";
            hold-trigger-on-release;
        };

        uj_backquote: uj_backquote {
            compatible = "zmk,behavior-hold-tap";
            label = "UJ_BACKQUOTE";
            bindings = <&jp_backquote>, <&backquote>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        uj_quote: uj_quote {
            compatible = "zmk,behavior-hold-tap";
            label = "UJ_QUOTE";
            bindings = <&jp_quote>, <&quote>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        uj_doublequote: uj_doublequote {
            compatible = "zmk,behavior-hold-tap";
            label = "UJ_DOUBLEQUOTE";
            bindings = <&jp_doublequote>, <&doublequote>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        uj_caret: uj_caret {
            compatible = "zmk,behavior-hold-tap";
            label = "UJ_CARET";
            bindings = <&jp_caret>, <&caret>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        uj_pipe: uj_pipe {
            compatible = "zmk,behavior-hold-tap";
            label = "UJ_PIPE";
            bindings = <&jp_pipe>, <&pipe>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        uj_at: uj_at {
            compatible = "zmk,behavior-hold-tap";
            label = "UJ_AT";
            bindings = <&jp_at>, <&at>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };

        uj_amp: uj_amp {
            compatible = "zmk,behavior-hold-tap";
            label = "UJ_AMP";
            bindings = <&jp_amp>, <&amp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        DEFAULT {
            bindings = <
&kp Q                         &kp W                          &holdtap LC(X) X                 &kp D      &kp Z                                               &slash                      &kp R                     &holdtap LG(E) E  &kp L  &kp P
&kp I                         &kp T                          &holdtap LC(A) A                 &kp K      &kp G             &kp C_MUTE         &lt 6 ESC      &kp MINUS                   &kp N                     &kp O             &kp U  &kp S
&mt LEFT_SHIFT Y              &kp H                          &holdtap LC(C) C                 &kp M      &kp B             &at                &kp SEMICOLON  &holdtap EXCLAMATION COMMA  &holdtap QUESTION PERIOD  &kp V             &kp F  &kp J
&holdtap LC(SPACE) LS(LC(M))  &holdtap LEFT_GUI LC(PAGE_UP)  &holdtap LEFT_ALT LC(PAGE_DOWN)  &mkp LCLK  &mt LSHIFT SPACE  &mt LCTRL TAB      &lt_bsdel 5 0  &lt 4 ENTER                                                                    &kp PRINTSCREEN
            >;

            sensor-bindings = <&inc_dec_kp C_VOLUME_DOWN C_VOLUME_UP>;
        };

        MOUSE {
            bindings = <
&trans  &trans  &trans  &trans  &trans                                            &trans  &trans     &trans             &trans     &trans
&trans  &trans  &trans  &trans  &trans             &trans                 &trans  &trans  &trans     &trans             &trans     &trans
&trans  &trans  &trans  &trans  &trans             &trans                 &trans  &trans  &mkp LCLK  &mkp_layer 2 MCLK  &mkp RCLK  &trans
&trans  &trans  &trans  &trans  &mkp_layer 2 MCLK  &mkp_layer 3 RCLK      &trans  &trans                                           &trans
            >;
        };

        SCROLL {
            bindings = <
&trans  &trans  &trans  &trans  &trans                      &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans                          &trans
            >;
        };

        SNIPE {
            bindings = <
&trans  &trans  &trans  &trans  &trans                      &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans                          &trans
            >;
        };

        NUMBER {
            bindings = <
&holdtap JP_ASTERISK ASTERISK   &kp NUMBER_7  &kp NUMBER_8  &kp NUMBER_9  &holdtap JP_PLUS PLUS                               &holdtap JP_TILDE TILDE   &uj_backquote 0 0  &uj_quote 0 0  &uj_doublequote 0 0  &uj_caret 0 0
&kp SLASH                      &kp NUMBER_4  &kp NUMBER_5  &kp NUMBER_6  &kp MINUS              &kp LC(NUMBER_0)      &trans  &kp LEFT                 &kp DOWN           &kp UP_ARROW   &kp RIGHT          &kp BACKSLASH
&kp NUMBER_0                   &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &holdtap JP_COLON COLON             &kp COMMA             &uj_pipe   &kp EXCLAMATION          &uj_at 0 0         &hash          &uj_amp 0 0        &dollar
&kp PERCENT                    &trans        &trans        &mkp RCLK     &mt LEFT_SHIFT EQUAL   &mt LCTRL PERIOD      &trans  &trans                                                                        &holdtap JP_UNDERSCORE UNDER 
            >;

            sensor-bindings = <&inc_dec_kp LC(MINUS) LC(PLUS)>;
        };

        FUNCTION {
            bindings = <
&holdtap JP_LEFT_BRACE  LEFT_BRACE             &kp F7          &kp F8          &kp F9     &kp F12                                                       &kp INSERT  &kp DELETE        &kp PRINTSCREEN  &kp PAUSE_BREAK  &holdtap JP_RIGHT_BRACE RIGHT_BRACE
&holdtap JP_LEFT_PARENTHESIS LEFT_PARENTHESIS  &kp F4          &kp F5          &kp F6     &kp F11           &kp LC(NUMBER_1)        &trans              &kp HOME    &kp PAGE_DOWN     &kp PAGE_UP      &kp END          &holdtap JP_RIGHT_PARENTHESIS RIGHT_PARENTHESIS
&holdtap JP_LEFT_BRACKET LEFT_BRACKET           &kp F1          &kp F2          &kp F3     &kp F10           &kp LC(LA(DELETE))      &kp LC(LS(ESCAPE))  &kp C_PREV  &kp C_PLAY_PAUSE  &kp C_PAUSE      &kp C_NEXT       &holdtap JP_RIGHT_BRACKET RIGHT_BRACKET
&kp CAPSLOCK                                   &kp SCROLLLOCK  &kp KP_NUMLOCK  &mkp MCLK  &mt LSHIFT LC(Z)  &mt LCTRL LC(Y)         &trans              &trans                                                          &kp K_CONTEXT_MENU
            >;

            sensor-bindings = <&inc_dec_kp LC(PAGE_UP) LC(PAGE_DOWN)>;
        };

        SYSTEM {
            bindings = <
&ind_bat     &trans        &trans        &ind_con      &out OUT_USB                          &out OUT_USB  &ind_con      &trans        &trans        &ind_bat
&trans       &bt BT_SEL 3  &bt BT_SEL 4  &trans        &trans        &bt BT_CLR      &trans  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
&trans       &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &out OUT_BLE  &trans          &trans  &out OUT_BLE  &trans        &trans        &trans        &trans
&bootloader  &trans        &trans        &trans        &trans        &trans          &trans  &trans                                                  &bootloader
            >;
        };
    };
};
